# ============================================================
#  Variables de entorno — copiá este archivo como .env.local
# ============================================================

# Access Token de Mercado Pago (Producción o Test).
# Lo obtenés en: https://www.mercadopago.com.ar/developers/panel/app
# Como Integrador Oficial usá tu Access Token de producción para cobrar real.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL pública del sitio (para los back_urls del checkout).
# En local: http://localhost:3000  |  En producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
